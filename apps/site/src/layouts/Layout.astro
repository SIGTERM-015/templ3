---
import { BootSequence } from '../components/os/BootSequence'
import CRTOverlay from '../components/os/CRTOverlay.astro'
import { DesktopShell } from '../components/os/DesktopShell'
import { site } from '../data/siteConfig'
import '../styles/global.css'

type Props = {
  title?: string
  description?: string
  initialApp?: string
  serverData?: string
  maximized?: boolean
  errorMessage?: string
  /** Overrides from CMS SiteIdentity — passed by pages that pre-fetch it */
  siteName?: string
  siteDescription?: string
  /**
   * Root-relative path to the Open Graph image (e.g. '/api/og/home.png').
   * When provided, emits og:image, og:image:width, og:image:height, twitter:image,
   * and og:url meta tags. Defaults to '/api/og/home.png' when omitted.
   */
  ogImage?: string
}

const {
  title,
  description,
  initialApp,
  serverData,
  maximized,
  errorMessage,
  siteName,
  siteDescription,
  ogImage = '/api/og/home.png',
} = Astro.props

// CMS values take priority, then explicit props, then siteConfig fallback
const resolvedSiteName = siteName ?? site.name
const resolvedDescription = siteDescription ?? description ?? site.description
const resolvedTitle = title ?? `${resolvedSiteName} | Sigterm`

// Build absolute OG image URL from the request origin
const ogImageUrl = new URL(ogImage, Astro.url.origin).href
const canonicalUrl = Astro.url.origin + Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <link href="/sigterm-logo.svg" rel="icon" type="image/svg+xml" />
    <meta content={Astro.generator} name="generator" />
    <meta content={resolvedDescription} name="description" />
    <meta content={resolvedSiteName} property="og:site_name" />
    <meta content={resolvedTitle} property="og:title" />
    <meta content={resolvedDescription} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content={ogImageUrl} property="og:image" />
    <meta content="1200" property="og:image:width" />
    <meta content="630" property="og:image:height" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content="summary_large_image" name="twitter:card" />
    <meta content={ogImageUrl} name="twitter:image" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{resolvedTitle}</title>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="https://cdn.jsdelivr.net/fontsource/fonts/monaspace-neon@latest/latin-400-normal.woff2"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="https://cdn.jsdelivr.net/fontsource/fonts/monaspace-argon@latest/latin-400-normal.woff2"
    />
    <script is:inline>
      try {
        if (sessionStorage.getItem('templ3-booted')) {
          document.documentElement.classList.add('skip-boot')
        }
      } catch {}
    </script>
  </head>
  <body>
    <BootSequence client:idle />
    <DesktopShell
      client:load
      initialApp={initialApp}
      serverData={serverData}
      maximized={maximized}
      errorMessage={errorMessage}
    />
    <CRTOverlay />
  </body>
</html>
