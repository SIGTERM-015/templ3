---
import { BootSequence } from '../components/os/BootSequence'
import CRTOverlay from '../components/os/CRTOverlay.astro'
import { DesktopShell } from '../components/os/DesktopShell'
import MonitorFrame from '../components/os/MonitorFrame.astro'
import { site } from '../data/siteConfig'
import '../styles/global.css'

type Props = {
  title?: string
  description?: string
  initialApp?: string
  serverData?: string
  maximized?: boolean
  /** Overrides from CMS SiteIdentity — passed by pages that pre-fetch it */
  siteName?: string
  siteDescription?: string
}

const {
  title,
  description,
  initialApp,
  serverData,
  maximized,
  siteName,
  siteDescription,
} = Astro.props

// CMS values take priority, then explicit props, then siteConfig fallback
const resolvedSiteName = siteName ?? site.name
const resolvedDescription = siteDescription ?? description ?? site.description
const resolvedTitle = title ?? `${resolvedSiteName} | Sigterm`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <link href="/sigterm-logo.svg" rel="icon" type="image/svg+xml" />
    <meta content={Astro.generator} name="generator" />
    <meta content={resolvedDescription} name="description" />
    <meta content={resolvedSiteName} property="og:site_name" />
    <meta content={resolvedTitle} property="og:title" />
    <meta content={resolvedDescription} property="og:description" />
    <meta content="website" property="og:type" />
    <meta content="summary_large_image" name="twitter:card" />
    <title>{resolvedTitle}</title>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="https://cdn.jsdelivr.net/fontsource/fonts/monaspace-neon@latest/latin-400-normal.woff2"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      crossorigin
      href="https://cdn.jsdelivr.net/fontsource/fonts/monaspace-argon@latest/latin-400-normal.woff2"
    />
    <script is:inline>
      if (sessionStorage.getItem('templ3-booted') || window.location.search.includes('maximized')) {
        document.documentElement.classList.add('has-booted')
        sessionStorage.setItem('templ3-booted', '1')
      }
    </script>
  </head>
  <body>
    <BootSequence client:load />
    <MonitorFrame>
      <DesktopShell
        client:load
        initialApp={initialApp}
        serverData={serverData}
        maximized={maximized}
      />
      <CRTOverlay />
    </MonitorFrame>
  </body>
</html>
