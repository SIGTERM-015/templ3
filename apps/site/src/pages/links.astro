---
import Layout from '../layouts/Layout.astro'
import { getLinks, getSiteIdentity, getWebApps } from '../lib/cms'

export const prerender = false

const [links, siteIdentity, webApps] = await Promise.all([
  getLinks(),
  getSiteIdentity(),
  getWebApps(),
])
---

<Layout
  title={siteIdentity?.siteName ? `Links | ${siteIdentity.siteName}` : 'Links | Templ3'}
  description="Sigterm's public links."
  initialApp="comms"
  serverData={JSON.stringify({ links, siteIdentity, webApps })}
/>
