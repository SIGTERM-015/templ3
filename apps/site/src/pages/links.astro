---
import Layout from '../layouts/Layout.astro'
import { getLinks, getSiteIdentity } from '../lib/cms'

export const prerender = false

const [links, siteIdentity] = await Promise.all([
  getLinks(),
  getSiteIdentity(),
])
---

<Layout
  title={siteIdentity?.siteName ? `Links | ${siteIdentity.siteName}` : 'Links | Templ3'}
  description="Sigterm's public links."
  initialApp="comms"
  serverData={JSON.stringify({ links, siteIdentity })}
/>
