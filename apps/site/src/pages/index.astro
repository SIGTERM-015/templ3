---
import Layout from '../layouts/Layout.astro'
import { getSiteIdentity, getWebApps } from '../lib/cms'

export const prerender = false

const [siteIdentity, webApps] = await Promise.all([
  getSiteIdentity(),
  getWebApps(),
])
---

<Layout
  initialApp="dossier"
  serverData={JSON.stringify({ siteIdentity, webApps })}
  siteName={siteIdentity?.siteName}
  siteDescription={siteIdentity?.siteDescription}
/>
