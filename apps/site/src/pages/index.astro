---
import Layout from '../layouts/Layout.astro'
import { getSiteIdentity } from '../lib/cms'

export const prerender = false

const siteIdentity = await getSiteIdentity()
---

<Layout
  initialApp="dossier"
  serverData={JSON.stringify({ siteIdentity })}
  siteName={siteIdentity?.siteName}
  siteDescription={siteIdentity?.siteDescription}
/>
