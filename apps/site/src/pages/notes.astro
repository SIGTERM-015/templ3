---
import Layout from '../layouts/Layout.astro'
import { getNotes, getSiteIdentity, getWebApps } from '../lib/cms'

export const prerender = false

const [notes, siteIdentity, webApps] = await Promise.all([
  getNotes(),
  getSiteIdentity(),
  getWebApps(),
])
---

<Layout
  title={siteIdentity?.siteName ? `Notes | ${siteIdentity.siteName}` : 'Notes | Templ3'}
  description="Notes and markdown files."
  initialApp="notes"
  serverData={JSON.stringify({ notes, siteIdentity, webApps })}
  maximized={Astro.url.searchParams.has('maximized')}
/>
