---
import Layout from '../layouts/Layout.astro'
import { getFavouriteMedia, getMediaTypes, getMediaStatuses, getSiteIdentity } from '../lib/cms'

export const prerender = false

const [media, mediaTypes, mediaStatuses, siteIdentity] = await Promise.all([
  getFavouriteMedia(),
  getMediaTypes(),
  getMediaStatuses(),
  getSiteIdentity(),
])
---

<Layout
  title={siteIdentity?.siteName ? `Favourite Media | ${siteIdentity.siteName}` : 'Favourite Media | Templ3'}
  description="Anime, games, books, and everything Sigterm has watched, read, and played."
  initialApp="media"
  serverData={JSON.stringify({ media, mediaTypes, mediaStatuses, siteIdentity })}
  maximized={Astro.url.searchParams.has('maximized')}
/>
